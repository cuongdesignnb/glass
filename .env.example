# ============================================
# Glass Eyewear - Environment Variables
# ============================================

# === Development (local) ===
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Glass Eyewear

# === Production Server (thêm vào .env.local trên server) ===
# NEXT_PUBLIC_API_URL=https://mitoo.vn/api
# NEXT_PUBLIC_APP_URL=https://mitoo.vn
#
# SSR Internal API (Next.js gọi Laravel qua 127.0.0.1, 
# tránh DNS/SSL timeout khi server tự gọi chính nó)
# INTERNAL_API_URL=http://127.0.0.1/api
# API_HOST=mitoo.vn
