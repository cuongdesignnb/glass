APP_NAME="Glass Eyewear"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=glass_eyewear
DB_USERNAME=root
DB_PASSWORD=

SANCTUM_STATEFUL_DOMAINS=localhost:3000

SESSION_DRIVER=file
SESSION_LIFETIME=120

FRONTEND_URL=http://localhost:3000

# OpenAI - AI content/articles/images
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium

# Gemini - ONLY product virtual try-on
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-image

# IMAGE_GENERATOR is legacy. Article AI images always use OpenAI.
